# Runtime state (must stay outside version control)
/data/
/backups/
/releases/
/logs/
/tmp/
/.cache/
*.log
*.pid
*.dmp

# SQLite transient files and accidental root-level databases
/*.db
/*.sqlite
/*.sqlite3
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm
*.sqlite3-wal
*.sqlite3-shm

# Local configuration and secrets
.env
.env.*
!.env.example
*.local.json
*.local.yaml
*.local.yml
/configs/exam-monitor.json

# Go build, test, profiling, and workspace output
/bin/
/build/
*.exe
*.test
*.out
coverage.out
/coverage/
*.prof
*.pprof
go.work
go.work.sum

# Frontend dependencies and generated output
node_modules/
.pnpm-store/
dist/
.next/
.vite/
.nyc_output/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python tooling (future optional analysis only)
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Test and tool output
test-results/
TestResults/
playwright-report/
*.tmp
*.temp

# Editors and IDEs
.vscode/
.idea/
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Operating system metadata
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
