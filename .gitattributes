* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf

# Repository text files
*.md text eol=lf
*.txt text eol=lf
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
VERSION text eol=lf

# Windows-native scripts
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary evidence and test fixtures
*.db binary
*.sqlite binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.mp4 binary
*.mkv binary
*.webm binary
*.wav binary
*.zip binary
