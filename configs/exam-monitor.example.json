{
  "schema_version": 1,
  "runtime": {
    "mode": "record-only",
    "backup_interface_enabled": true
  },
  "server": {
    "listen_address": "127.0.0.1:47831",
    "allow_non_loopback": false,
    "read_header_timeout": "5s",
    "read_timeout": "10s",
    "write_timeout": "10s",
    "idle_timeout": "30s",
    "shutdown_timeout": "10s"
  },
  "paths": {
    "data_directory": "data"
  },
  "storage": {
    "busy_timeout": "5s",
    "max_open_connections": 8
  },
  "api": {
    "max_request_bytes": 1048576,
    "max_batch_events": 100,
    "max_event_bytes": 65536,
    "max_payload_depth": 16,
    "max_concurrent_writes": 4,
    "default_page_size": 100,
    "max_page_size": 500
  },
  "media_ingest": {
    "enabled": false,
    "inbox_directory": "media-inbox",
    "scan_interval": "1s",
    "settle_interval": "1s",
    "max_segment_bytes": 2147483648,
    "max_segment_duration": "10m",
    "max_sidecar_bytes": 65536,
    "max_scan_entries": 1000,
    "ffprobe_path": "",
    "ffprobe_timeout": "30s"
  },
  "collectors": [
    {
      "id": "activitywatch.afk.local",
      "kind": "activitywatch",
      "enabled": false,
      "heartbeat_period": "1m",
      "allowed_lateness": "1m",
      "offline_after": "5m",
      "planned_schedule": {
        "timezone": "Asia/Shanghai",
        "windows": [
          {
            "days": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
            "start_local": "00:00",
            "end_local": "24:00"
          }
        ]
      },
      "activitywatch": {
        "base_url": "http://127.0.0.1:5600",
        "bucket_id": "aw-watcher-afk_HOSTNAME",
        "poll_interval": "30s",
        "request_timeout": "5s",
        "initial_lookback": "24h",
        "rescan_window": "1h",
        "page_size": 100,
        "max_pages_per_poll": 20,
        "max_response_bytes": 4194304,
        "clock_error_ms": 1000
      }
    },
    {
      "id": "generic.local",
      "kind": "generic_json",
      "enabled": false,
      "heartbeat_period": "1m",
      "allowed_lateness": "1m",
      "offline_after": "5m",
      "planned_schedule": {
        "timezone": "Asia/Shanghai",
        "windows": [
          {
            "days": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
            "start_local": "00:00",
            "end_local": "24:00"
          }
        ]
      }
    },
    {
      "id": "desk.media",
      "kind": "media",
      "enabled": false,
      "heartbeat_period": "5m",
      "allowed_lateness": "5m",
      "offline_after": "15m",
      "planned_schedule": {
        "timezone": "Asia/Shanghai",
        "windows": [
          {
            "days": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
            "start_local": "00:00",
            "end_local": "24:00"
          }
        ]
      }
    }
  ],
  "timeline": {
    "clock_uncertain_after": "1s",
    "max_query_range": "744h",
    "max_projection_facts": 100000
  },
  "logging": {
    "level": "info"
  }
}
